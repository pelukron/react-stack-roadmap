#!/bin/bash
# Pre-push hook: bloquea push directo a main
# Regla: todo cambio debe pasar por PR.
# Tags siempre permitidos.

branch=$(git rev-parse --abbrev-ref HEAD)

blocked=false
while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_ref" = "refs/heads/main" ] && [ "$branch" = "main" ]; then
        blocked=true
    fi
done

if $blocked; then
    echo ""
    echo "🚫 PUSH DIRECTO A MAIN BLOQUEADO"
    echo ""
    echo "   Regla: Todo cambio debe pasar por PR."
    echo ""
    echo "   Flujo correcto:"
    echo "     1. git checkout -b feat/num-descripcion"
    echo "     2. Hacer cambios + commit"
    echo "     3. Push + PR en GitHub"
    echo "     4. CI verde + approve → merge"
    echo ""
    exit 1
fi
