# Auto-detect text files and normalize line endings to LF on checkout
* text=auto eol=lf

# Explicitly declare files that are binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.pdf binary

# Ensure diffable text files are treated correctly
*.md text
*.json text
*.yaml text
*.yml text
*.ts text
*.tsx text
*.js text
*.jsx text
*.css text
*.html text
*.svg text
